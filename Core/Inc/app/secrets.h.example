/**
 * secrets.h.example  —  copy to secrets.h and fill in your values.
 *
 *   cp Core/Inc/app/secrets.h.example Core/Inc/app/secrets.h
 *
 * secrets.h is git-ignored (see .gitignore) so your token is never committed.
 */
#ifndef APP_SECRETS_H
#define APP_SECRETS_H

/* Base host of the yfinance proxy (no scheme, no trailing slash). */
#define STOCK_API_HOST        "rozakos.eu"

/* TLS port. */
#define STOCK_API_PORT        443

/* Path prefix for the API (see CYD-Stock-Ticker: /stocks/api/v1). */
#define STOCK_API_BASE_PATH   "/stocks/api/v1"

/* Bearer token issued by your proxy. KEEP PRIVATE. */
#define STOCK_API_TOKEN       "PUT-YOUR-BEARER-TOKEN-HERE"

#endif /* APP_SECRETS_H */
